{
  "name": "mindful-break",
  "version": "2.0.0",
  "description": "Social media detox — web application",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "node scripts/prepare-www.js",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:run:android": "npm run cap:sync && npx cap run android"
  },
  "capacitor": {
    "platforms": [
      "android"
    ]
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "bcryptjs": "^2.4.3",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.21.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "serve": "^14.2.4"
  }
}
