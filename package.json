{

{
  "outputDirectory": "."
}





  "name": "mindful-break",
  "version": "1.0.0",
  "description": "Social media detox — mobile app",
  "private": true,
  "scripts": {
    "build": "node scripts/prepare-www.js",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:run:android": "npm run cap:sync && npx cap run android",
    "serve": "npm run build && npx serve www -p 8080"
  },
  "capacitor": {
    "platforms": [
      "android"
    ]
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "serve": "^14.2.4"
  },
  "dependencies": {
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  }
}
